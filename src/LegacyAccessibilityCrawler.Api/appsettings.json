{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Crawler": {
    "ScanMode": "dynamic",
    "BrowserMode": "modern-edge",
    "MaxPages": 25,
    "CrawlDepth": 2,
    "DelaySeconds": 1,
    "SameDomainOnly": true,
    "RespectRobotsTxt": true,
    "CaptureScreenshots": true,
    "CaptureHtml": true,
    "EnableKeyboardChecks": true,
    "EnableWcag22EnhancedRules": false,
    "EnableSection508Rules": true,
    "EnableMicrosoftAxe": false,
    "MicrosoftAxeRunnerPath": "",
    "MicrosoftAxeTimeoutSeconds": 30,
    "FallbackToStaticStairWhenBrowserUnavailable": true,
    "EnablePdfRuleOverlay": true,
    "RedactQueryStrings": true,
    "AllowedDomains": []
  },
  "Security": {
    "BaseOutputDirectory": "reports",
    "BaseInputDirectory": "inputs",
    "AllowPrivateNetworkTargets": false,
    "MaxPagesLimit": 100,
    "MaxDepthLimit": 5,
    "MaxDelaySecondsLimit": 30,
    "JobTimeoutMinutes": 30,
    "MaxPdfBytes": 26214400,
    "MaxCsvBytes": 5242880,
    "EnableSwagger": false,
    "EnableUi": false
  },
  "DetailedErrors": false,
  "AllowedHosts": "*"
}
