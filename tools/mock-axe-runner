#!/usr/bin/env python3
"""Minimal local axe-core-compatible runner for integration testing."""

import argparse
import json
from pathlib import Path


def main() -> int:
    parser = argparse.ArgumentParser(description="Emit one mock axe-core violation.")
    parser.add_argument("--input", required=True, help="Path to captured HTML input file.")
    parser.add_argument("--url", required=True, help="Original page URL.")
    args = parser.parse_args()

    html_path = Path(args.input)
    html = html_path.read_text(encoding="utf-8", errors="replace")
    snippet = html[:500]

    result = {
        "url": args.url,
        "violations": [
            {
                "id": "mock-button-name",
                "impact": "serious",
                "description": "Mock violation: button elements must have discernible text.",
                "help": "Buttons must have discernible text.",
                "helpUrl": "https://dequeuniversity.com/rules/axe/4.10/button-name",
                "tags": ["wcag412", "wcag2a", "section508"],
                "nodes": [
                    {
                        "target": ["button.mock-a11y-test"],
                        "html": snippet,
                        "failureSummary": "Mock failure: the test runner received page HTML and emitted a deterministic violation."
                    }
                ]
            }
        ],
        "passes": [],
        "incomplete": [],
        "inapplicable": []
    }

    print(json.dumps(result, indent=2))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
